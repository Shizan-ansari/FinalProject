<% layout("layouts/boilerplate") %>
<head>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body class="container mt-4">
  <h2>My Bookings</h2>
  <hr>

  <% if (orders.length === 0) { %>
    <p class="text-muted">You don’t have any bookings yet.</p>
  <% } else { %>
    <div class="row">
      <% orders.forEach(order => { %>
        <div class="col-md-6 mb-3">
          <div class="card">
            <div class="card-body">
              <% if (order.listing) { %>
                <h5><%= order.listing.title %></h5>
                <p><strong>Check-in:</strong> <%= order.checkIn.toDateString() %></p>
                <p><strong>Check-out:</strong> <%= order.checkOut.toDateString() %></p>
                <p><strong>Guests:</strong> <%= order.guests %></p>
                <p><strong>Location:</strong><%= order.listing.location %></p>
                <p><strong>Status:</strong> 
                  <span class="badge bg-success">Confirmed</span>
                </p>

                <!-- Cancel Button -->
                <button class="btn btn-sm btn-outline-danger cancel-btn" 
                        data-id="<%= order._id %>">Cancel Booking</button>
              <% } else { %>
                <h5 class="text-danger">Listing not available</h5>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script>
    $(".cancel-btn").click(function() {
      const orderId = $(this).data("id");

      Swal.fire({
        title: 'Are you sure?',
        text: "Once cancelled, refund will be processed within 5–7 days.",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Yes, cancel it!',
        cancelButtonText: 'No, keep it'
      }).then((result) => {
        if (result.isConfirmed) {
          $.ajax({
            url: `/cancelBooking/${orderId}`,
            method: "DELETE",   // <-- DELETE request
            success: function(res) {
              if (res.success) {
                Swal.fire('Cancelled!', res.msg, 'success').then(() => {
                  window.location.reload();
                });
              } else {
                Swal.fire('Error', res.msg, 'error');
              }
            },
            error: function() {
              Swal.fire('Error', 'Server error while cancelling.', 'error');
            }
          });
        }
      });
    });
  </script>
</body>
