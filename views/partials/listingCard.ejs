<a href="/listings/<%= listing._id %>" class="listing-link">
  <div class="card col listing-card">
    <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height: 20rem;"/>
    <div class="card-img-overlay"></div>
    <div class="card-body">
      <p class="card-text">
        <strong><%= listing.title %></strong>
        <p>
          <i class="fas fa-map-marker-alt me-2 icon-loc"></i>
          <%= listing.location %>, <%= listing.country %>
        </p>
        <!-- ✅ Price Section -->
        <p class="price-listing">
          <% if (listing.isOffer && listing.offerPrice) { %>
            <!-- Original Price (cut) -->
            <span style="text-decoration: line-through; color: grey;">
              &#8377;<%= listing.price.toLocaleString("en-IN") %>
            </span>
            &nbsp;
            <!-- Offer Price -->
            <strong style="color: red;">
              &#8377;<%= listing.offerPrice.toLocaleString("en-IN") %>
            </strong> / night
          <% } else { %>
            <!-- Normal Price -->
            <strong>&#8377;<%= listing.price.toLocaleString("en-IN") %></strong> / night
          <% } %>
        </p>
      </p>
    </div>
  </div>
</a>
