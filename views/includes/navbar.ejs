<style>
  .btn-search {
    background-color: #FF6B6B;
    color: white;
    border-radius: 25px;
    padding: 0 1rem 0 1rem;
  }
  .btn-search:hover {
    background-color: #FF6B6B;
    color: white;
  }
  .btn-search i {
    display: inline;
    margin-right: 0.5rem;
  }
  .search-input {
    border-radius: 25px;
    padding: 0.5rem 3rem 0.5rem 3rem;
    font-size: 1rem;
  }
</style>

<nav class="navbar navbar-expand-lg bg-body-light border-bottom sticky-top d-none d-lg-flex">
  <div class="container-fluid">
    <a class="navbar-brand" href="/listings">
      <img src="/assets/ikkon.png" alt="Wanderstay Logo" height="40">
    </a>

    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <div class="navbar-nav">
        <a class="nav-link" href="/listings">Explore</a> &nbsp;&nbsp;&nbsp;

        <% if (currUser && (currUser.role === "admin" || (currUser._id && currUser._id.toString() === GLOBAL_ADMIN_ID))) { %>
          <a href="/listings/admin" class="nav-link">Admin</a>
        <% } else if (currUser) { %>
          <a href="/my-bookings" class="mt-2 ms-2 text-primary text-decoration-none">MyBookings</a>
        <% } %>
      </div>
    </div>

    <div class="navbar-nav ms-auto w-100">
      <form class="navbar-nav offset-1 mb-2 d-flex align-items-center justify-content-between p-2 bg-light rounded shadow-sm"
        role="search" action="/listings/search" method="GET" style="gap: 15px;">

        <div>
          <label class="form-label small mb-1">Destination</label>
          <input name="q" class="form-control" type="search" placeholder="City,Title, or Location"/>
        </div>

        <div>
          <label class="form-label small mb-1">Check-In</label>
          <input type="date" id="checkIn" name="checkIn" class="form-control" />
          <div class="invalid-feedback">Please select a valid check-in date (within 1 year).</div>
        </div>

        <div>
          <label class="form-label small mb-1">Check-Out</label>
          <input type="date" id="checkOut" name="checkOut" class="form-control" />
          <div class="invalid-feedback">Please select a valid check-out date (within 1 year, after check-in).</div>
        </div>

        <div>
          <label class="form-label small mb-1">Price per Night</label>
          <select name="priceRange" class="form-control">
            <option value="">Any</option>
            <option value="0-1500">₹0 - ₹1500</option>
            <option value="1500-2500">₹1500 - ₹2500</option>
            <option value="2500-5000">₹2500 - ₹5000</option>
            <option value="5000+">₹5000+</option>
          </select>
        </div>

        <div class="d-flex align-items-end">
          <button class="btn btn-danger h-100 px-4" type="submit">
            <i class="fa-solid fa-magnifying-glass"></i> Search
          </button>
        </div>
      </form>
    </div>

    <div class="navbar-nav ms-auto">
      <% if (currUser && currUser.role === "admin") { %>
        <a class="nav-link text-nowrap" href="/listings/new">Add New Listing</a>
      <% } %>

      <% if(!currUser) {%>
        <a class="btn btn-danger ms-2 text-nowrap" aria-current="page" href="/signup"><b>SignUP</b></a> &nbsp;
        <a class="btn btn-success text-nowrap" href="/login"><b>Log in</b></a>
      <% } %>
      <% if(currUser) {%>
        <a class="btn btn-danger nav-link text-nowrap" href="/logout"><b>Log out</b></a>
      <% } %>
    </div>
  </div>
</nav>

<nav class="navbar navbar-expand-lg bg-body-light border-bottom sticky-top d-lg-none">
  <div class="container-fluid">
    <a class="navbar-brand" href="/listings">
      <img src="/assets/ikkon.png" alt="Wanderstay Logo" height="40">
    </a>

    <button class="navbar-toggler" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasNavbar" aria-controls="offcanvasNavbar" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
  </div>
</nav>

<div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasNavbar" aria-labelledby="offcanvasNavbarLabel">
  <div class="offcanvas-header">
    <h5 class="offcanvas-title" id="offcanvasNavbarLabel">Menu</h5>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
  </div>
  <div class="offcanvas-body">
    <div class="navbar-nav">
      <a class="nav-link" href="/listings">Explore</a>
      <% if (currUser && (currUser.role === "admin" || (currUser._id && currUser._id.toString() === GLOBAL_ADMIN_ID))) { %>
        <a href="/listings/admin" class="nav-link">Admin</a>
      <% } else if (currUser) { %>
        <a href="/my-bookings" class="mt-2 text-primary text-decoration-none">MyBookings</a>
      <% } %>
    </div>

    <hr>

    <form class="d-flex flex-column" role="search" action="/listings/search" method="GET" style="gap: 15px;">
      <div>
        <label class="form-label small mb-1">Destination</label>
        <input name="q" class="form-control" type="search" placeholder="City,Title, or Location"/>
      </div>

      <div>
        <label class="form-label small mb-1">Check-In</label>
        <input type="date" id="checkInOffcanvas" name="checkIn" class="form-control" />
      </div>

      <div>
        <label class="form-label small mb-1">Check-Out</label>
        <input type="date" id="checkOutOffcanvas" name="checkOut" class="form-control" />
      </div>

      <div>
        <label class="form-label small mb-1">Price per Night</label>
        <select name="priceRange" class="form-control">
          <option value="">Any</option>
          <option value="0-1500">₹0 - ₹1500</option>
          <option value="1500-2500">₹1500 - ₹2500</option>
          <option value="2500-5000">₹2500 - ₹5000</option>
          <option value="5000+">₹5000+</option>
        </select>
      </div>

      <div class="mt-3">
        <button class="btn btn-danger w-100" type="submit">
          <i class="fa-solid fa-magnifying-glass"></i> Search
        </button>
      </div>
    </form>

    <hr>

    <div class="navbar-nav">
      <% if (currUser && currUser.role === "admin") { %>
        <a class="nav-link text-nowrap" href="/listings/new">Add New Listing</a>
      <% } %>

      <% if(!currUser) {%>
        <a class="btn btn-danger ms-2 text-nowrap mt-2" aria-current="page" href="/signup"><b>SignUP</b></a>
        <a class="btn btn-success text-nowrap mt-2" href="/login"><b>Log in</b></a>
      <% } %>
      <% if(currUser) {%>
        <a class="btn btn-danger nav-link text-nowrap mt-2" href="/logout"><b>Log out</b></a>
      <% } %>
    </div>
  </div>
</div>


<script>
  const checkIn = document.getElementById("checkIn");
  const checkOut = document.getElementById("checkOut");
  const checkInOffcanvas = document.getElementById("checkInOffcanvas");
  const checkOutOffcanvas = document.getElementById("checkOutOffcanvas");

  const today = new Date().toISOString().split("T")[0];
  const maxDate = new Date();
  maxDate.setFullYear(maxDate.getFullYear() + 1);
  const maxDateStr = maxDate.toISOString().split("T")[0];

  function setupDateInputs(checkInInput, checkOutInput) {
    checkInInput.setAttribute("min", today);
    checkInInput.setAttribute("max", maxDateStr);
    checkOutInput.setAttribute("min", today);
    checkOutInput.setAttribute("max", maxDateStr);

    checkInInput.addEventListener("change", function () {
      checkOutInput.setAttribute("min", this.value);
    });
  }

  // Setup date inputs for both the main and offcanvas forms
  setupDateInputs(checkIn, checkOut);
  setupDateInputs(checkInOffcanvas, checkOutOffcanvas);

  // Prevent form submission if invalid
  document.querySelector("form").addEventListener("submit", function (e) {
    let valid = true;
    const currentCheckIn = e.target.querySelector('input[name="checkIn"]');
    const currentCheckOut = e.target.querySelector('input[name="checkOut"]');

    if (currentCheckIn && (currentCheckIn.value < today || currentCheckIn.value > maxDateStr)) {
      currentCheckIn.classList.add("is-invalid");
      valid = false;
    } else {
      currentCheckIn.classList.remove("is-invalid");
      currentCheckIn.classList.add("is-valid");
    }

    if (
      currentCheckOut &&
      (currentCheckOut.value <= currentCheckIn.value || currentCheckOut.value > maxDateStr)
    ) {
      currentCheckOut.classList.add("is-invalid");
      valid = false;
    } else {
      currentCheckOut.classList.remove("is-invalid");
      currentCheckOut.classList.add("is-valid");
    }

    if (!valid) {
      e.preventDefault(); // stop search
    }
  });
</script>