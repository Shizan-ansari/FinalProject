<% layout("layouts/boilerplate") %>

<body>
  <div class="container my-4">

    <!-- Show applied filters -->
    <h3 class="mb-3 search-result">
      Search Results
    </h3>
    <p class="mb-3 offset-3 text-muted">
      Destination: <%= q || "Any" %> |
      Check-In: <%= checkIn || "Any" %> |
      Check-Out: <%= checkOut || "Any" %> |
      Price Range: <%= priceRange || "Any" %>
    </p>

    <!-- Results -->
    <% if (results.length === 0) { %>
      <p class="mb-3 search-result">No listings matched your search.</p>
    <% } else { %>
      <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-3 g-3">
        <% results.forEach(listing => { %>
          <a href="/listings/<%= listing._id %>" 
             class="listing-link" 
             style="text-decoration:none; color:inherit;">
            <div class="card col listing-card">
              <img src="<%= listing.image?.url %>" 
                   class="card-img-top" 
                   alt="listing_image" 
                   style="height: 20rem; object-fit: cover;" />
              <div class="card-body">
                <p class="card-text mb-1">
                  <strong><%= listing.title %></strong>
                </p>
                <p class="mb-1">
                  <i class="fas fa-map-marker-alt me-2 icon-loc"></i>
                  <%= listing.location %>, <%= listing.country %>
                </p>
                <p class="price-listing mb-0">
                  <strong>&#8377;<%= Number(listing.price || 0).toLocaleString("en-IN") %></strong> / night
                </p>
              </div>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>
  </div>
</body>
